# Canonical site URL (used by sitemap.xml, robots.txt and page metadata).
# Set this to your custom domain after binding it in Netlify, e.g.
# https://www.sunvoltenergy.com  — no trailing slash needed.
NEXT_PUBLIC_SITE_URL=https://www.sunvoltenergy.com

# Google Analytics 4 Measurement ID
# Get it from: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification (add as meta tag)
# Get it from: https://search.google.com/search-console → Add Property → HTML tag
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# Tawk.to Live Chat
# Get it from: https://www.tawk.to → Dashboard → Administration → Chat Widget → Direct Chat Link
# The URL format is: https://embed.tawk.to/PROPERTY_ID/WIDGET_ID
NEXT_PUBLIC_TAWK_PROPERTY_ID=6a0d545989fa791c3b1cc488
NEXT_PUBLIC_TAWK_WIDGET_ID=1jp21308j
